FROM golang:1.24 AS builder

WORKDIR /app

COPY go.mod go.sum ./
RUN go mod download

COPY . .

WORKDIR /app/web
RUN npm install --legacy-peer-deps
RUN npm run build

WORKDIR /app
RUN go build -o memos .

FROM debian:bookworm-slim

WORKDIR /app

RUN useradd -m -u 10001 appuser

COPY --from=builder /app/memos /app/memos

RUN mkdir -p /var/opt/memos && chown -R appuser:appuser /var/opt/memos /app

USER appuser

EXPOSE 8081

CMD ["/app/memos"]